{
  "name": "ta7ady-elgeel",
  "productName": "Ta7ady ElGeel",
  "version": "2.0.0",
  "private": true,
  "description": "Ta7ady ElGeel v2.0 clean source rebuild.",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"npm run build:electron && wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "build": "npm run typecheck && vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "npm run build:electron && electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "package:win": "npm run build && electron-builder --win portable",
    "package:clean": "npm run package:win",
    "check:localization": "node scripts/check-localization-hardcoded-text.mjs",
    "audit:release": "node scripts/audit-release-package.mjs",
    "smoke:v2": "node scripts/run-v2-smoke-check.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "6.0.2",
    "vite": "8.0.14",
    "typescript": "6.0.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "electron": "42.3.3"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "concurrently": "10.0.0",
    "cross-env": "10.1.0",
    "wait-on": "9.0.10",
    "vitest": "4.1.9",
    "eslint": "10.5.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "com.ta7ady.elgeel",
    "productName": "Ta7ady ElGeel",
    "directories": {
      "output": "release-v2"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "asar": true,
    "win": {
      "target": "portable",
      "icon": "public/favicon.ico"
    }
  }
}
