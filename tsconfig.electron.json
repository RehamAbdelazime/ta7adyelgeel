{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": [
      "ES2022"
    ],
    "types": [
      "node",
      "electron"
    ],
    "rootDir": "src/desktop-electron",
    "outDir": "dist-electron",
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": [
    "src/desktop-electron/**/*.ts",
    "src/desktop-electron/**/*.cts"
  ]
}
